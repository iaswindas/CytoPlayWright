{
  "version": "1",
  "sourceRoots": [
    "cypress"
  ],
  "specGlobs": [
    "cypress/e2e/**/*.spec.js",
    "cypress/e2e/**/*.js"
  ],
  "supportFile": "cypress/support/e2e.js",
  "tsconfigPath": "tsconfig.json",
  "outputRoot": "playwright",
  "customCommandMap": {},
  "wrapperMap": {
    "aliasHelpers": [],
    "mappings": {}
  },
  "taskMap": {},
  "interceptPolicies": {},
  "pomRules": {
    "preserve": [],
    "upgrade": [],
    "regenerate": []
  },
  "pluginModules": [],
  "runtimeRecipeModules": [],
  "typeFallbacks": {
    "externalModulesAsAny": true
  },
  "reporting": {
    "unresolvedThreshold": 0.8,
    "inlineTodoPrefix": "TODO(cypw)",
    "strictControlFlow": false,
    "maxBestEffortDepth": 2
  }
}
